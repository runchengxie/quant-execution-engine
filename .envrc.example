# Copy to .envrc and allow direnv to load local paper/safe development secrets.
# Requires direnv: https://direnv.net

# Do not put LongPort real tokens in repo-local .env* or .envrc* files.
# Use ~/.config/qexec/longport-live.env or current-shell exports for live.

# Load environment variables from .env files if they exist.
dotenv_if_exists .env
dotenv_if_exists .env.local

# Default sync profile:
#   --group dev --extra cli
# Optional local override examples:
#   UV_SYNC_ARGS="--group dev --extra cli --extra alpaca"
#   UV_SYNC_ARGS="--group dev --extra cli --extra longport"
#   UV_SYNC_ARGS="--group dev --extra cli --extra ibkr"
#   NO_DEV=1

watch_file pyproject.toml
watch_file uv.lock
watch_file requirements.txt
watch_file requirements-dev.txt
watch_file .env
watch_file .env.local

has_cmd() { command -v "$1" >/dev/null 2>&1; }

has_any_env() {
  for key in "$@"; do
    eval "value=\${$key:-}"
    [ -n "$value" ] && return 0
  done
  return 1
}

warn_uv_sync_failed() {
  echo "warning: uv sync failed, the environment might be incomplete" >&2
}

warn_pip_install_failed() {
  echo "warning: failed to install $1" >&2
}

ensure_venv_uv() {
  if [ ! -d .venv ]; then
    uv venv --seed || return 1
  fi
  # shellcheck disable=SC1091
  source .venv/bin/activate
}

ensure_venv_py() {
  if [ ! -d .venv ]; then
    python3 -m venv .venv || python -m venv .venv
  fi
  # shellcheck disable=SC1091
  source .venv/bin/activate
  python -m pip install --upgrade pip setuptools wheel >/dev/null 2>&1 || true
}

if has_cmd uv; then
  # Default to the repo's standard dev environment; override locally via UV_SYNC_ARGS.
  UV_SYNC_ARGS="${UV_SYNC_ARGS:---group dev --extra cli}"
  [ -n "$NO_DEV" ] && UV_SYNC_ARGS="${UV_SYNC_ARGS/--group dev/}"

  add_uv_extra_if_missing() {
    case " $UV_SYNC_ARGS " in
      *" --extra $1 "*)
        ;;
      *)
        UV_SYNC_ARGS="$UV_SYNC_ARGS --extra $1"
        ;;
    esac
  }

  if has_any_env \
    ALPACA_API_KEY APCA_API_KEY_ID ALPACA_SECRET_KEY APCA_API_SECRET_KEY; then
    add_uv_extra_if_missing alpaca
  fi
  # LONGBRIDGE_* names are deprecated compatibility fallbacks.
  if has_any_env \
    LONGPORT_APP_KEY LONGPORT_APP_SECRET LONGPORT_ACCESS_TOKEN_TEST \
    LONGPORT_ACCESS_TOKEN LONGBRIDGE_APP_KEY LONGBRIDGE_APP_SECRET \
    LONGBRIDGE_ACCESS_TOKEN LONGBRIDGE_ACCESS_TOKEN_TEST; then
    add_uv_extra_if_missing longport
  fi
  if has_any_env IBKR_HOST IBKR_PORT IBKR_PORT_PAPER IBKR_CLIENT_ID IBKR_ACCOUNT_ID; then
    add_uv_extra_if_missing ibkr
  fi

  if ensure_venv_uv; then
    if [ -f uv.lock ]; then
      uv sync --frozen $UV_SYNC_ARGS || warn_uv_sync_failed
    else
      uv sync $UV_SYNC_ARGS || warn_uv_sync_failed
    fi
  else
    echo "notice: uv venv failed, falling back to python venv + pip" >&2
    ensure_venv_py
  fi
else
  echo "notice: uv not detected, using the python venv + pip method" >&2
  ensure_venv_py
  if [ -f requirements-dev.txt ] && [ -z "$NO_DEV" ]; then
    pip install -r requirements-dev.txt || warn_pip_install_failed requirements-dev.txt
  elif [ -f requirements.txt ]; then
    pip install -r requirements.txt || warn_pip_install_failed requirements.txt
  elif [ -f pyproject.toml ]; then
    pip install -e . || warn_pip_install_failed '"." with pip'
  fi
fi
