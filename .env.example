# Copy this file as .env and fill in the broker credentials you actually use.

# --- LongPort API ---

# Configure region
LONGPORT_REGION="cn"                    # hk | cn | sg | us

# Enable extended-hours handling when the broker/session API allows it
LONGPORT_ENABLE_OVERNIGHT="true"       # true | false

# Required credentials
# LongPort real and paper accounts share App Key / Secret, but use different Access Tokens.
LONGPORT_APP_KEY="your_app_key_here"
LONGPORT_APP_SECRET="your_app_secret_here"
LONGPORT_ACCESS_TOKEN="your_real_access_token_here"
LONGPORT_ACCESS_TOKEN_TEST="your_paper_access_token_here"

# Optional local limits (0 = unlimited / warning-only where noted)
LONGPORT_MAX_NOTIONAL_PER_ORDER="0"     # warning-only; broker risk control still authoritative
LONGPORT_MAX_QTY_PER_ORDER="0"          # enforced on non-dry-run path

# Optional local trading window fallback
LONGPORT_TRADING_WINDOW_START="09:30"
LONGPORT_TRADING_WINDOW_END="16:00"

# Optional FX fallback for non-USD broker balances
FX_HKD_USD="0.128"

# --- Alpaca Paper API ---
#
# Requires optional dependency:
#   uv sync --group dev --extra cli --extra alpaca
#
# Either ALPACA_* or APCA_* names can be used. Keep only one pair in your local .env.

ALPACA_API_KEY="your_alpaca_api_key_here"
ALPACA_SECRET_KEY="your_alpaca_secret_key_here"
