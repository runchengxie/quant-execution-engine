# Copy this file as .env and fill in real API credentials

# --- FRED API for fetching risk-free rates (sharpe ratio calculations) ---

FRED_API_KEY="your_fred_key_here"

# --- Gemini API ---

GEMINI_API_KEY="your_gemini_key_here"

# Optional, for concurrent Gemini model calls

GEMINI_API_KEY_2="your_gemini_key_2_here"
GEMINI_API_KEY_3="your_gemini_key_3_here"

# --- Long Bridge API ---

# Configure Region
LONGPORT_REGION="cn"                    # hk | cn

# Enable Overnight Quotes
LONGPORT_ENABLE_OVERNIGHT="true"        # true | false

# Account Related Settings
LONGPORT_APP_KEY="your_app_key_here"
LONGPORT_APP_SECRET="your_app_secret_here"

# Real Account Access Token
LONGPORT_ACCESS_TOKEN="your_real_access_token_here"

# Default Account
LONGPORT_DEFAULT_ENV="real"             # test | real

# Optional Local Risk Controls (0 = unlimited)
LONGPORT_MAX_NOTIONAL_PER_ORDER="0"     # e.g., 20000 for $20k cap; 0 for unlimited
LONGPORT_MAX_QTY_PER_ORDER="0"          # e.g., 500 shares cap; 0 for unlimited

# Optional Local Trading Window (fallback only; broker session takes precedence)
LONGPORT_TRADING_WINDOW_START="09:30"
LONGPORT_TRADING_WINDOW_END="16:00"
